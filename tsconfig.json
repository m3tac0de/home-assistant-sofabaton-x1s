{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "strict": true,
    "skipLibCheck": true,
    "allowJs": false,
    "isolatedModules": true,
    "noEmit": true,
    "useDefineForClassFields": false
  },
  "include": [
    "custom_components/sofabaton_x1s/www/src/**/*.ts",
    "tests/frontend/**/*.ts",
    "scripts/**/*.mjs"
  ]
}
